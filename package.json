{
  "name": "chen-blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch --env-file=.env server/index.js",
    "dev:all": "concurrently -n ui,api -c cyan,yellow \"npm run dev\" \"npm run dev:server\"",
    "start": "node --env-file=.env server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "db:migrate": "node --env-file=.env server/db/migrate.js",
    "db:seed": "node --env-file=.env server/db/seed.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@neondatabase/serverless": "^1.1.0",
    "@toast-ui/editor": "^3.2.2",
    "@vercel/blob": "^0.23.4",
    "gsap": "^3.12.5",
    "hono": "^4.6.14",
    "katex": "^0.17.0",
    "marked": "^18.0.5",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "concurrently": "^9.1.2",
    "vite": "^6.3.1"
  }
}
