# Auto detect text files and perform LF normalization
* text=auto

# JavaScript/JSON/Vue files should use LF
*.js text eol=lf
*.json text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.env text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
